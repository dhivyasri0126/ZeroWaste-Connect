# Server Configuration
PORT=8081

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/zerowaste_connect
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password

# Security Configuration
SECURITY_USER_NAME=Admin
SECURITY_USER_PASSWORD=admin@123

# Logging Configuration
LOG_LEVEL_SECURITY=INFO
SHOW_SQL=false

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# CORS Configuration
# Comma-separated list of allowed origins for production
# Example: https://your-frontend-url.onrender.com,https://www.your-frontend-url.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# JWT Configuration
# IMPORTANT: Change this to a strong random secret in production
JWT_SECRET=ThisIsMySecretKeyForZeroWasteConnectProject123456
JWT_EXPIRATION=86400000
